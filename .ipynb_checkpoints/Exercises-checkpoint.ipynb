   "cell_type": "markdown",
   "id": "02ad85db-a7fe-43c8-9622-7836755c5587",
   "metadata": {},
   "source": [
    "### Given a number, replace all 0's into 1's."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "74bbba7f-d4ed-481c-9337-b9956de9897d",
   "metadata": {},
   "outputs": [],
   "source": [
    "value = input()\n",
    "value = str(value)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "108da1ff-1997-4fe6-bcd1-40e04081c047",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Turns out that which() is an R function.\n",
    "\n",
    "indices = which(value) == \"0\"\n",
    "value[indices] = \"1\"\n",
    "#return(value)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "984475c6-d1fc-4a13-8b64-63c74fafa991",
   "metadata": {},
   "outputs": [],
   "source": [
    "for i in value:\n",
    "    if i == \"0\":\n",
    "        i = 1\n",
    "        "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d7fd855b-5723-4808-8409-875d735407f3",
   "metadata": {},
   "outputs": [],
   "source": []
  }
